    <Node ToolID="292">
      <GuiSettings Plugin="AlteryxGuiToolkit.TextBox.TextBox">
        <Position x="92" y="150" width="1008" height="84" />
      </GuiSettings>
      <Properties>
        <Configuration>
          <Text>Prerequisites: This workflow uses GenAI tools. You must have an Alteryx One subscription and use Designer 2025.2 or later. Additionally, please set up LLM in Alteryx One to ensure that the GenAI category tools function correctly. Users are responsible for subscribing to, setting up, and paying fees to each LLM vendor for their LLM needs.</Text>
          <Font name="メイリオ" size="9.75" style="0" />
          <TextColor name="Red" />
          <FillColor name="White" />
          <Shape shape="3" />
          <Justification Justification="3" />
        </Configuration>
