          <Notebook><![CDATA[{"cells":[{"metadata":{"ayx":{"cell_css":"border: 3px solid #357; margin: 4px; background: #fbffff","contents_keyword":"Alteryx.help()","label":"info"}},"cell_type":"markdown","source":["Run `Alteryx.help()` for info about useful functions.  \n","i.e., `Alteryx.read(\"#1\")`, `Alteryx.write(df,1)`, `Alteryx.getWorkflowConstant(\"Engine.WorkflowDirectory\")`"]},{"metadata":{"ayx":{"cell_css":"border: 1px solid #58a; margin: 2px;","contents_keyword":"installPackages","label":"deps"},"execution":{"iopub.execute_input":"2026-03-15T02:12:00.001206Z","iopub.status.busy":"2026-03-15T02:12:00.000669Z","iopub.status.idle":"2026-03-15T02:12:02.368043Z","shell.execute_reply":"2026-03-15T02:12:02.366780Z"}},"cell_type":"code","source":["# List all non-standard packages to be imported by your \n","# script here (only missing packages will be installed)\n","from ayx import Package\n","Package.installPackages(['networkx','Pillow'])\n"],"execution_count":1,"outputs":[]},{"metadata":{"execution":{"iopub.execute_input":"2026-03-15T02:12:02.409031Z","iopub.status.busy":"2026-03-15T02:12:02.409031Z","iopub.status.idle":"2026-03-15T02:12:15.362780Z","shell.execute_reply":"2026-03-15T02:12:15.361428Z"}},"cell_type":"code","source":["\"\"\"\n","Alteryx Workflow Visualizer - Alteryx Pythonツール版 ver1.1\n","=====================================================\n","【概要】\n","  AlteryxのPythonツール内で動作する、ワークフロー可視化スクリプト。\n","  上流から「ノードテーブル」「接続テーブル」を受け取り、\n","  ワークフローID (___Record_ID___) ごとに画像を生成して\n","  ファイルパスを下流に渡す。\n","\n","【Alteryxワークフロー上の接続】\n","  Input #1 : ノードテーブル     (nodes_df)\n","  Input #2 : 接続テーブル       (edges_df)\n","  Output#1 : 出力パステーブル   (result_df)\n","\n","【ノードテーブル (Input #1) 必須カラム】\n","  ___Record_ID___  : ワークフローを識別するID (文字列 or 数値)\n","  ToolID           : ツールの一意ID (整数)\n","  ToolName         : Designer上のツール名 (例: Filter, Join, Formula)\n","  ToolCategory     : Designer上のカテゴリ名 (例: Preparation, Join, In/Out)\n","  x                : キャンバス上のX座標 (数値)\n","  y                : キャンバス上のY座標 (数値)\n","  Label            : ツール表示名 (省略可。空の場合はToolNameを使用)\n","\n","【接続テーブル (Input #2) 必須カラム】\n","  ___Record_ID___  : ワークフローを識別するID\n","  SrcToolID        : 接続元のToolID (整数)\n","  DstToolID        : 接続先のToolID (整数)\n","  ConnectionName   : 接続名 (例: Output / True / False / Error)\n","\n","【設定】\n","  OUTPUT_DIR         : 画像の保存先ディレクトリ\n","  ICONS_DIR          : アイコン画像ディレクトリ (省略可)\n","  DPI                : 出力解像度\n","  ICON_SIZE          : アイコン表示サイズ (px)\n","  CATEGORY_COLOR_MAP : ToolCategoryごとの色設定 (下記参照)\n","\"\"\"\n","\n","# ═══════════════════════════════════════════════════════════\n","# ▼ ユーザー設定 ここを編集してください ▼\n","# ═══════════════════════════════════════════════════════════\n","OUTPUT_DIR = r\"\"      # 画像の保存先 (空の場合は TempFilePath を自動使用)\n","ICONS_SUBDIR = \"icons\"   # ワークフローフォルダ直下のアイコンフォルダ名\n","DPI        = 96\n","ICON_SIZE  = 24\n","LABEL_WRAP_WIDTH = 16   # ラベルの折り返し文字数 (半角換算)\n","LABEL_OFFSET_PT = 8 # ラベルのツールからの距離\n","NODE_ID_FONTSIZE = 8   # ノードIDバッジのフォントサイズ\n","NODE_ID_OFFSET_PT = 16   # ノードIDバッジのアイコン中心からのオフセット (ポイント単位)\n","LABEL_FONTSIZE = 9   # ノードラベルのフォントサイズ\n","NODE_GAP_RATIO   = 5.0 # ノード間の中央値距離を ICON_SIZE の何倍にするか (大きいほど広がる)\n","\n","# コンテナ描画設定\n","CONTAINER_PADDING     = 20   # 左右・下部の余白\n","CONTAINER_PADDING_TOP = 20   # 上部の基本余白 (ラベル高さが自動加算される)\n","CONTAINER_ALPHA    = 0.08  # コンテナ塗りつぶしの透明度\n","CONTAINER_EDGE_ALPHA = 0.6 # コンテナ枠線の透明度\n","CONTAINER_LABEL_SIZE = 8   # コンテナラベルのフォントサイズ\n","CONTAINER_LABEL_COLOR = \"#dcdcdc\"  # コンテナラベルの文字色\n","\n","# ★ 日本語フォント設定を追加\n","import matplotlib\n","matplotlib.rcParams[\"font.family\"] = \"sans-serif\"\n","matplotlib.rcParams[\"font.sans-serif\"] = [\n","    \"Meiryo\",           # Windows 推奨\n","    \"Yu Gothic\",        # Windows\n","    \"MS Gothic\",        # Windows (fallback)\n","    \"Hiragino Sans\",    # macOS\n","    \"IPAexGothic\",      # Linux\n","    \"Noto Sans CJK JP\", # Linux (Noto)\n","]\n","matplotlib.rcParams[\"axes.unicode_minus\"] = False  # マイナス記号の文字化け防止\n","\n","# 接続種別 → (色, 線種) のマッピング\n","# 線種: \"solid\"(実線) / \"dashed\"(破線) / \"dotted\"(点線)\n","EDGE_STYLE_MAP = {\n","    \"default\":  (\"#90CAF9\", \"solid\"),   # 通常接続\n","    \"wireless\": (\"#90CAF9\", \"dotted\"),  # Wireless接続\n","    \"control\":  (\"#FF9800\", \"dashed\"),  # Control / Log\n","    \"question\": (\"#00BCD4\", \"solid\"),   # Question\n","    \"action\":   (\"#CE93D8\", \"solid\"),   # Action\n","    \"true\":     (\"#4CAF50\", \"solid\"),   # True / 条件一致\n","    \"false\":    (\"#F44336\", \"solid\"),   # False / Error\n","}\n","\n","# ToolCategory (Designer Tool Category) → 色のマッピング\n","# ・キーはAlteryxのカテゴリ名に合わせて編集してください\n","# ・\"default\" は未定義カテゴリへのフォールバック色\n","CATEGORY_COLOR_MAP = {\n","    \"In/Out\":            \"#009D8D\",   \n","    \"Preparation\":       \"#0065A8\",  \n","    \"Join\":              \"#7A52A0\",   \n","    \"Parse\":             \"#96B149\",   \n","    \"Transform\":         \"#E25F45\",  \n","    \"In-Database\":       \"#41547A\",\n","    \"Reporting\":         \"#E29343\",   \n","    \"Documentation\":     \"#647492\",  \n","    \"Spatial\":           \"#009031\",   \n","    \"Machine Learning\":  \"#00A8C9\",\n","    \"Text Mining\":       \"#5C63C7\",\n","    \"Computer Vision\":   \"#A22843\",\n","    \"Interface\":         \"#606F8C\",\n","    \"Data Investigation\":\"#7DBEBB\",\n","    \"Predictive\":        \"#90542F\",  \n","    \"AB Testing\":        \"#34D14D\",\n","    \"Time Series\":       \"#F86F51\",\n","    \"Predictive Grouping\":\"#8CA679\",\n","    \"Prescriptive\":      \"#0273C4\",\n","    \"Connectors\":        \"#B3B3B3\",\n","    \"Address\":           \"#0080A3\",\n","    \"Demographic Analysis\":\"#C42262\",\n","    \"Calgary\":           \"#A53794\",\n","    \"Developer\":         \"#96B1B6\", \n","    \"Laboratory\":        \"#669496\",\n","    \"GenAI\":             \"#06717C\",\n","    \"SDK samples\":       \"#505050\", \n","    \"default\":           \"#165F98\",   # fallback\n","}\n","# ═══════════════════════════════════════════════════════════\n","\n","import gc\n","import os\n","from pathlib import Path\n","from typing import Optional\n","\n","import matplotlib\n","matplotlib.use(\"Agg\")  # GUIなし・メモリ効率の良いバックエンドを強制\n","import matplotlib.patches as mpatches\n","import matplotlib.pyplot as plt\n","import matplotlib.patheffects as pe\n","import networkx as nx\n","from matplotlib.offsetbox import AnnotationBbox, OffsetImage\n","from PIL import Image\n","import numpy as np\n","import pandas as pd\n","\n","# Alteryx Python tool API\n","from ayx import Alteryx\n","\n","\n","# ──────────────────────────────────────────────\n","# カテゴリ → 色の解決\n","# ──────────────────────────────────────────────\n","def _category_color(category: str) -> str:\n","    \"\"\"ToolCategoryから色コードを返す。未定義の場合はdefaultを使用。\"\"\"\n","    return CATEGORY_COLOR_MAP.get(str(category).strip(), CATEGORY_COLOR_MAP[\"default\"])\n","\n","def _char_width(ch: str) -> int:\n","    \"\"\"全角文字を2、半角文字を1として文字幅を返す。\"\"\"\n","    cp = ord(ch)\n","    # CJK統合漢字・ひらがな・カタカナ・全角記号など\n","    if (0x1100 <= cp <= 0x115F or 0x2E80 <= cp <= 0x303E or\n","            0x3040 <= cp <= 0xA4CF or 0xAC00 <= cp <= 0xD7A3 or\n","            0xF900 <= cp <= 0xFAFF or 0xFE10 <= cp <= 0xFE1F or\n","            0xFE30 <= cp <= 0xFE4F or 0xFF01 <= cp <= 0xFF60 or\n","            0xFFE0 <= cp <= 0xFFE6 or 0x1F300 <= cp <= 0x1FAFF):\n","        return 2\n","    return 1\n"," \n"," \n","def _wrap_label(text: str, max_width: int) -> str:\n","    \"\"\"\n","    全角・半角を考慮して max_width (半角換算) で折り返す。\n","    日本語のようにスペースのないテキストにも対応。\n","    \"\"\"\n","    lines = []\n","    for paragraph in text.splitlines():          # 既存の改行は尊重\n","        line, width = [], 0\n","        for ch in paragraph:\n","            cw = _char_width(ch)\n","            if width + cw > max_width and line:  # 超えたら改行\n","                lines.append(\"\".join(line))\n","                line, width = [], 0\n","            line.append(ch)\n","            width += cw\n","        if line:\n","            lines.append(\"\".join(line))\n","    return \"\\n\".join(lines) if lines else text\n","\n","# ──────────────────────────────────────────────\n","# アイコンローダー (ToolNameベースで検索)\n","# ──────────────────────────────────────────────\n","class IconLoader:\n","    def __init__(self, icons_dir: str, icon_size: int = ICON_SIZE):\n","        self.icons_dir = Path(icons_dir)\n","        self.icon_size = icon_size\n","        self._cache: dict[str, Optional[np.ndarray]] = {}\n"," \n","    def get(self, tool_name: str) -> Optional[np.ndarray]:\n","        \"\"\"ToolNameに対応するアイコン画像を返す。見つからない場合はNone。\"\"\"\n","        key = str(tool_name)\n","        if key in self._cache:\n","            return self._cache[key]\n","        img = self._load(key)\n","        self._cache[key] = img\n","        return img\n"," \n","    def _load(self, tool_name: str) -> Optional[np.ndarray]:\n","        if not self.icons_dir.exists():\n","            return None\n"," \n","        # ToolNameをそのままファイル名として検索\n","        # 例: \"Filter\" → Filter.png / filter.png\n","        candidates = []\n","        if tool_name:\n","            candidates = [\n","                f\"{tool_name}.png\",\n","                f\"{tool_name.lower()}.png\",\n","                f\"{tool_name}.svg\",\n","                f\"{tool_name.lower()}.svg\",\n","                f\"{tool_name}.ico\",\n","            ]\n"," \n","        for name in candidates:\n","            path = self.icons_dir / name\n","            if path.exists():\n","                try:\n","                    img = Image.open(path).convert(\"RGBA\")\n","                    img.thumbnail((self.icon_size * 2, self.icon_size * 2), Image.LANCZOS)\n","                    img = img.resize((self.icon_size, self.icon_size), Image.LANCZOS)\n","                    return np.array(img)\n","                except Exception:\n","                    continue\n","        return None\n","\n","# ──────────────────────────────────────────────\n","# 1ワークフロー分の描画処理\n","# ──────────────────────────────────────────────\n","def visualize_single(\n","    record_id,\n","    nodes_df: pd.DataFrame,\n","    edges_df: pd.DataFrame,\n","    icon_loader: IconLoader,\n","    output_dir: Path,\n",") -> str:\n","    \"\"\"\n","    1つのワークフロー分を描画して保存し、ファイルパスを返す。\n"," \n","    Parameters\n","    ----------\n","    record_id   : ___Record_ID___ の値\n","    nodes_df    : 該当ワークフローのノード行\n","                  (ToolID, ToolName, ToolCategory, x, y, Label)\n","    edges_df    : 該当ワークフローの接続行\n","                  (SrcToolID, DstToolID, ConnectionName)\n","    icon_loader : IconLoader インスタンス\n","    output_dir  : 保存先ディレクトリ\n"," \n","    Returns\n","    -------\n","    str : 保存した画像のファイルパス\n","    \"\"\"\n","    # ── グラフ構築 ──\n","    G = nx.DiGraph()\n"," \n","    for _, row in nodes_df.iterrows():\n","        def _clean(val) -> str:\n","            \"\"\"None / \"None\" / 空白のみ → 空文字に統一する\"\"\"\n","            s = str(val).strip() if val is not None else \"\"\n","            return \"\" if s.lower() == \"none\" else s\n"," \n","        tool_name     = _clean(row.get(\"ToolName\", \"\"))\n","        tool_category = _clean(row.get(\"ToolCategory\", \"\"))\n","        # Labelが空・None・\"None\"の場合はToolNameを表示名として使用\n","        label = _clean(row.get(\"Label\", \"\")) or tool_name or str(row[\"ToolID\"])\n"," \n","        container_id_raw = row.get(\"ContainerID\", \"\")\n","        container_id = _clean(container_id_raw)\n"," \n","        # Styleカラム (なければ空文字)\n","        style_fill   = _clean(row.get(\"StyleFillColor\", \"\"))\n","        style_border = _clean(row.get(\"StyleBorderColor\", \"\"))\n","        style_trans  = _clean(row.get(\"StyleTransparency\", \"\"))\n","        style_text   = _clean(row.get(\"StyleTextColor\", \"\"))\n"," \n","        G.add_node(\n","            int(row[\"ToolID\"]),\n","            tool_name=tool_name,\n","            tool_category=tool_category,\n","            label=label,\n","            x=float(row.get(\"x\", 0)),\n","            y=float(row.get(\"y\", 0)),\n","            container_id=container_id,\n","            style_fill=style_fill,\n","            style_border=style_border,\n","            style_trans=style_trans,\n","            style_text=style_text,\n","        )\n"," \n","    for _, row in edges_df.iterrows():\n","        G.add_edge(\n","            int(row[\"SrcToolID\"]),\n","            int(row[\"DstToolID\"]),\n","            connection=str(row.get(\"ConnectionName\", \"Output\")),\n","            dst_connection=str(row.get(\"DstConnection\", \"\")),\n","            wireless=str(row.get(\"Wireless\", \"\")).strip().lower() == \"true\",\n","        )\n"," \n","    if len(G.nodes) == 0:\n","        # ノードが0件の場合はメッセージ画像を生成して返す\n","        fig, ax = plt.subplots(figsize=(8, 4), facecolor=\"#1E1E2E\")\n","        ax.set_facecolor(\"#1E1E2E\")\n","        ax.axis(\"off\")\n","        ax.text(0.5, 0.55, \"There is no node.\",\n","                ha=\"center\", va=\"center\", transform=ax.transAxes,\n","                fontsize=20, color=\"#78909C\", fontweight=\"bold\")\n","        ax.text(0.5, 0.38, f\"[ID: {record_id}]\",\n","                ha=\"center\", va=\"center\", transform=ax.transAxes,\n","                fontsize=11, color=\"#546E7A\")\n","        safe_id = str(record_id).replace(\"/\", \"_\").replace(\"\\\\\", \"_\").replace(\":\", \"_\")\n","        out_path = output_dir / f\"workflow_{safe_id}.png\"\n","        plt.savefig(str(out_path), dpi=DPI, bbox_inches=\"tight\",\n","                    facecolor=fig.get_facecolor())\n","        plt.close()\n","        gc.collect()\n","        return str(out_path)\n"," \n","    # ── レイアウト ──\n","    xs = [d[\"x\"] for _, d in G.nodes(data=True)]\n","    ys = [d[\"y\"] for _, d in G.nodes(data=True)]\n","    has_coords = any(v != 0 for v in xs) or any(v != 0 for v in ys)\n"," \n","    if has_coords:\n","        pos = {nid: (d[\"x\"], -d[\"y\"]) for nid, d in G.nodes(data=True)}\n","    else:\n","        try:\n","            pos = nx.nx_agraph.graphviz_layout(G, prog=\"dot\", args=\"-Grankdir=LR\")\n","        except Exception:\n","            pos = nx.spring_layout(G, seed=42, k=2)\n"," \n","    # ── 座標を正規化して画像サイズ爆発を防ぐ ──\n","    all_x = [v for v, _ in pos.values()]\n","    all_y = [v for _, v in pos.values()]\n","    x_min_p, x_max_p = min(all_x), max(all_x)\n","    y_min_p, y_max_p = min(all_y), max(all_y)\n","    x_range = (x_max_p - x_min_p) or 1\n","    y_range = (y_max_p - y_min_p) or 1\n","    # x・yのうち広い方を基準に同じ係数でスケールして縦横比を保持\n","    max_range = max(x_range, y_range)\n","    NORM_SCALE = 1000.0\n","    pos = {\n","        nid: (\n","            (v_x - x_min_p) / max_range * NORM_SCALE,\n","            (v_y - y_min_p) / max_range * NORM_SCALE,\n","        )\n","        for nid, (v_x, v_y) in pos.items()\n","    }\n"," \n","    # ── Figureサイズをアイコンサイズから逆算 ──\n","    # ノード間の中央値距離が画面上で 2×ICON_SIZE pt になるよう\n","    # データ座標1単位 = 何ptかを決定し、Figureサイズを計算する\n","    all_nx = [v for v, _ in pos.values()]\n","    all_ny = [v for _, v in pos.values()]\n"," \n","    # ノード間距離の中央値を計算\n","    # Documentationカテゴリ (コンテナ等) は他ツールと重なる前提のため除外\n","    import itertools\n","    non_doc_nodes = {\n","        nid for nid in pos\n","        if G.nodes[nid].get(\"tool_category\", \"\").strip() != \"Documentation\"\n","    }\n","    edge_pairs = [\n","        (u, v) for u, v in G.edges()\n","        if u in pos and v in pos\n","        and u in non_doc_nodes and v in non_doc_nodes\n","    ]\n","    if len(edge_pairs) >= 1:\n","        dists = [\n","            ((pos[u][0] - pos[v][0])**2 + (pos[u][1] - pos[v][1])**2) ** 0.5\n","            for u, v in edge_pairs\n","        ]\n","    else:\n","        # エッジがない場合はDocumentation除外ノード間の全ペアで計算\n","        node_ids = list(non_doc_nodes) if non_doc_nodes else list(pos.keys())\n","        dists = [\n","            ((pos[a][0] - pos[b][0])**2 + (pos[a][1] - pos[b][1])**2) ** 0.5\n","            for a, b in itertools.combinations(node_ids, 2)\n","        ] or [NORM_SCALE]\n"," \n","    import statistics\n","    median_dist = statistics.median(dists) if dists else NORM_SCALE\n"," \n","    # 目標: 中央値距離 = 2 × ICON_SIZE pt\n","    # pt/データ単位 = (2 × ICON_SIZE) / median_dist\n","    target_gap_pt = icon_loader.icon_size * NODE_GAP_RATIO\n","    pt_per_unit = target_gap_pt / max(median_dist, 1e-6)\n"," \n","    # データ範囲をptに変換 → インチに変換 (1inch = 72pt)\n","    margin_unit = median_dist * 0.8   # 余白 = 中央値距離の0.8倍\n","    x_lo = min(all_nx) - margin_unit\n","    x_hi = max(all_nx) + margin_unit\n","    y_lo = min(all_ny) - margin_unit\n","    y_hi = max(all_ny) + margin_unit\n"," \n","    fig_w_pt = (x_hi - x_lo) * pt_per_unit\n","    fig_h_pt = (y_hi - y_lo) * pt_per_unit\n","    MAX_PT = 60 * 72   # 上限60インチ\n","    MIN_W_PT = 8 * 72\n","    MIN_H_PT = 5 * 72\n","    fig_w = max(min(fig_w_pt, MAX_PT), MIN_W_PT) / 72\n","    fig_h = max(min(fig_h_pt, MAX_PT), MIN_H_PT) / 72\n"," \n","    fig, ax = plt.subplots(figsize=(fig_w, fig_h), facecolor=\"#1E1E2E\")\n","    ax.set_facecolor(\"#1E1E2E\")\n","    ax.axis(\"off\")\n","    ax.set_xlim(x_lo, x_hi)\n","    ax.set_ylim(y_lo, y_hi)\n"," \n","    # ── エッジ種別の判定 ──\n","    def _edge_style(data: dict) -> tuple:\n","        \"\"\"EDGE_STYLE_MAP を参照して (color, linestyle) を返す。優先順位順に判定。\"\"\"\n","        conn     = data.get(\"connection\", \"\")\n","        dst_conn = data.get(\"dst_connection\", \"\")\n","        wireless = data.get(\"wireless\", False)\n","        if dst_conn == \"Control\" or conn == \"Log\":\n","            return EDGE_STYLE_MAP[\"control\"]\n","        if conn == \"Question\":\n","            return EDGE_STYLE_MAP[\"question\"]\n","        if conn == \"Action\":\n","            return EDGE_STYLE_MAP[\"action\"]\n","        if conn == \"True\":\n","            return EDGE_STYLE_MAP[\"true\"]\n","        if conn in (\"False\", \"Error\") or \"False\" in conn or \"Error\" in conn:\n","            return EDGE_STYLE_MAP[\"false\"]\n","        if wireless:\n","            return EDGE_STYLE_MAP[\"wireless\"]\n","        return EDGE_STYLE_MAP[\"default\"]\n"," \n","    # ── コンテナのグループ・バウンディングボックスを先に計算 ──\n","    # (エッジのコントロール接続の始点・終点調整に使用)\n","    from collections import defaultdict\n","    container_groups = defaultdict(list)\n","    for nid, data in G.nodes(data=True):\n","        cid = data.get(\"container_id\", \"\")\n","        if cid and cid in [str(n) for n in G.nodes]:\n","            container_groups[cid].append(nid)\n"," \n","    # コンテナのネスト深さを計算 (深いほど手前に描画)\n","    def _container_depth(cid: str, visited=None) -> int:\n","        if visited is None:\n","            visited = set()\n","        if cid in visited:\n","            return 0\n","        visited.add(cid)\n","        parent_cid = G.nodes[int(cid)].get(\"container_id\", \"\") if int(cid) in G.nodes else \"\"\n","        if parent_cid and parent_cid in [str(n) for n in G.nodes]:\n","            return 1 + _container_depth(parent_cid, visited)\n","        return 0\n"," \n","    # コンテナIDに対応するカラーパレット\n","    CONTAINER_COLORS = [\n","        \"#5B8FF9\", \"#5AD8A6\", \"#F6BD16\", \"#E86452\",\n","        \"#6DC8EC\", \"#945FB9\", \"#FF9845\", \"#1E9493\",\n","    ]\n"," \n","    sorted_containers = sorted(\n","        container_groups.keys(),\n","        key=lambda cid: _container_depth(cid),\n","        reverse=True,\n","    )\n"," \n","    # バウンディングボックス: cid → (x_min, x_max, y_min, y_max)\n","    # Figureキャップ後の実際のpt/データ単位をx・y別に計算してpaddingに反映\n","    actual_pt_per_unit_x = (fig_w * 72) / max(x_hi - x_lo, 1e-6)\n","    actual_pt_per_unit_y = (fig_h * 72) / max(y_hi - y_lo, 1e-6)\n","    icon_radius_x = (icon_loader.icon_size / 2) / max(actual_pt_per_unit_x, 1e-6)\n","    icon_radius_y = (icon_loader.icon_size / 2) / max(actual_pt_per_unit_y, 1e-6)\n","    pad_x   = CONTAINER_PADDING     + icon_radius_x   # 左右\n","    pad_y   = CONTAINER_PADDING     + icon_radius_y   # 下部\n"," \n","    container_boxes: dict[str, tuple] = {}\n","    # sorted_containers は深い順(内側→外側)なので内側のboxが先に確定している\n","    for cid in sorted_containers:\n","        member_ids = container_groups[cid]\n"," \n","        # コンテナラベルの行数からy_top paddingを計算\n","        cid_int = int(cid)\n","        container_node = G.nodes.get(cid_int, {})\n","        container_label = container_node.get(\"label\", \"\")\n","        line_count = len(container_label.splitlines()) if container_label else 1\n","        label_height_pt   = CONTAINER_LABEL_SIZE * 1.5 * line_count\n","        label_height_data = label_height_pt / max(actual_pt_per_unit_y, 1e-6)\n","        pad_y_top = CONTAINER_PADDING_TOP + icon_radius_y + label_height_data  # 上部\n"," \n","        xs_c = []\n","        ys_c = []\n","        for nid in member_ids:\n","            if str(nid) in container_boxes:\n","                # メンバーが内側コンテナの場合はそのboxの四隅を使用\n","                bx_min, bx_max, by_min, by_max = container_boxes[str(nid)]\n","                xs_c += [bx_min, bx_max]\n","                ys_c += [by_min, by_max]\n","            elif nid in pos:\n","                # 通常ノードは中心座標を使用\n","                xs_c.append(pos[nid][0])\n","                ys_c.append(pos[nid][1])\n","        if not xs_c:\n","            continue\n","        container_boxes[cid] = (\n","            min(xs_c) - pad_x,    # x_min\n","            max(xs_c) + pad_x,    # x_max\n","            min(ys_c) - pad_y,    # y_min 下部 (matplotlib座標: 下)\n","            max(ys_c) + pad_y_top,# y_max 上部 (matplotlib座標: 上)\n","        )\n"," \n","    def _control_endpoint(node_id: int, is_dst: bool) -> tuple | None:\n","        \"\"\"\n","        コンテナノードへのコントロール接続の端点座標を返す。\n","        is_dst=True  → 入力側(左上): コントロール入力\n","        is_dst=False → 出力側(右上): Log出力\n","        コンテナでなければ None を返す。\n","        \"\"\"\n","        cid = str(node_id)\n","        if cid not in container_boxes:\n","            return None\n","        x_min, x_max, _, y_max = container_boxes[cid]\n","        if is_dst:\n","            return (x_min, y_max)   # 左上\n","        else:\n","            return (x_max, y_max)   # 右上\n"," \n","    # ── コンテナ描画 (エッジ・ノードより低いzorderで描画) ──\n","    for idx, cid in enumerate(sorted_containers):\n","        if cid not in container_boxes:\n","            continue\n","        x_min, x_max, y_min, y_max = container_boxes[cid]\n","        width  = x_max - x_min\n","        height = y_max - y_min\n","        pad    = CONTAINER_PADDING\n"," \n","        cid_int = int(cid)\n","        container_node  = G.nodes.get(cid_int, {})\n","        container_label = container_node.get(\"label\", f\"Container #{cid}\")\n","        is_ctrl = container_node.get(\"tool_name\", \"\") == \"Control Container\"\n"," \n","        # Style情報の取得 (なければパレットにフォールバック)\n","        style_fill   = container_node.get(\"style_fill\", \"\")\n","        style_border = container_node.get(\"style_border\", \"\")\n","        style_trans  = container_node.get(\"style_trans\", \"\")\n","        style_text   = container_node.get(\"style_text\", \"\")\n"," \n","        fallback_color = CONTAINER_COLORS[idx % len(CONTAINER_COLORS)]\n","        fill_color   = style_fill   if style_fill   else fallback_color\n","        border_color = style_border if style_border else fallback_color\n","        # Transparency: 0=不透明 100=透明 → alpha = 1 - t/100\n","        try:\n","            fill_alpha = max(0.0, min(1.0, 1.0 - int(style_trans) / 100))\n","        except (ValueError, TypeError):\n","            fill_alpha = CONTAINER_ALPHA\n"," \n","        depth  = _container_depth(cid)\n","        zorder = 1 + depth\n"," \n","        if is_ctrl:\n","            # コントロールコンテナ: 角なし・二重線\n","            boxstyle_str = \"square,pad=0.0\"\n","            # 外枠（太め）\n","            ax.add_patch(mpatches.FancyBboxPatch(\n","                (x_min, y_min), width, height,\n","                boxstyle=boxstyle_str,\n","                facecolor=fill_color, edgecolor=border_color,\n","                linewidth=4, alpha=fill_alpha, zorder=zorder,\n","            ))\n","            # 内枠（細め・少し内側）\n","            inset = CONTAINER_PADDING * 0.15\n","            ax.add_patch(mpatches.FancyBboxPatch(\n","                (x_min + inset, y_min + inset),\n","                width - inset * 2, height - inset * 2,\n","                boxstyle=boxstyle_str,\n","                facecolor=\"none\", edgecolor=border_color,\n","                linewidth=1.5, alpha=CONTAINER_EDGE_ALPHA,\n","                linestyle=\"solid\", zorder=zorder,\n","            ))\n","        else:\n","            # 通常コンテナ: 角丸・実線\n","            boxstyle_str = \"round,pad=0.0\"\n","            ax.add_patch(mpatches.FancyBboxPatch(\n","                (x_min, y_min), width, height,\n","                boxstyle=boxstyle_str,\n","                facecolor=fill_color, edgecolor=border_color,\n","                linewidth=2, alpha=fill_alpha, zorder=zorder,\n","            ))\n","            ax.add_patch(mpatches.FancyBboxPatch(\n","                (x_min, y_min), width, height,\n","                boxstyle=boxstyle_str,\n","                facecolor=\"none\", edgecolor=border_color,\n","                linewidth=2, alpha=CONTAINER_EDGE_ALPHA,\n","                linestyle=\"solid\", zorder=zorder,\n","            ))\n"," \n","        label_color = CONTAINER_LABEL_COLOR\n","        ax.text(\n","            x_min + pad * 0.3, y_max - pad * 0.3,\n","            container_label,\n","            ha=\"left\", va=\"top\",\n","            fontsize=CONTAINER_LABEL_SIZE,\n","            color=label_color,\n","            fontweight=\"bold\",\n","            alpha=0.95,\n","            path_effects=[pe.withStroke(linewidth=2, foreground=\"#1E1E2E\")],\n","            zorder=zorder + 1,\n","        )\n"," \n","    # ── エッジを線種グループごとに分けて描画 ──\n","    # コントロール系かつ始点/終点がコンテナの場合は FancyArrowPatch で別途描画\n","    from matplotlib.patches import FancyArrowPatch\n"," \n","    normal_edge_groups = defaultdict(list)   # networkx で描画するエッジ\n","    container_control_edges = []             # FancyArrowPatch で描画するエッジ\n"," \n","    for src, dst, data in G.edges(data=True):\n","        style_key = _edge_style(data)\n","        conn     = data.get(\"connection\", \"\")\n","        dst_conn = data.get(\"dst_connection\", \"\")\n","        is_control = (dst_conn == \"Control\" or conn == \"Log\")\n"," \n","        src_pt = _control_endpoint(src, is_dst=False) if (is_control and conn == \"Log\") else None\n","        dst_pt = _control_endpoint(dst, is_dst=True)  if (is_control and dst_conn == \"Control\") else None\n"," \n","        if is_control and (src_pt is not None or dst_pt is not None):\n","            # 始点・終点のどちらかがコンテナ → FancyArrowPatch で描画\n","            container_control_edges.append((src, dst, data, src_pt, dst_pt))\n","        else:\n","            normal_edge_groups[style_key].append((src, dst))\n"," \n","    # 通常エッジ (networkx)\n","    common_kw = dict(\n","        ax=ax,\n","        arrows=True, arrowstyle=\"-|>\", arrowsize=18,\n","        width=1.8, alpha=0.85,\n","        connectionstyle=\"arc3,rad=0.05\",\n","        min_source_margin=icon_loader.icon_size * 0.6,\n","        min_target_margin=icon_loader.icon_size * 0.6,\n","    )\n","    for (color, linestyle), edge_list in normal_edge_groups.items():\n","        nx.draw_networkx_edges(\n","            G, pos, edgelist=edge_list,\n","            edge_color=color, style=linestyle,\n","            **common_kw,\n","        )\n"," \n","    # コンテナコントロールエッジ (FancyArrowPatch)\n","    ls_map = {\"solid\": \"-\", \"dashed\": \"--\", \"dotted\": \":\"}\n","    for src, dst, data, src_pt, dst_pt in container_control_edges:\n","        color, linestyle = _edge_style(data)\n","        # 始点: src_pt があればそれ、なければ通常ノード座標\n","        p_src = src_pt if src_pt is not None else pos.get(src, (0, 0))\n","        # 終点: dst_pt があればそれ、なければ通常ノード座標\n","        p_dst = dst_pt if dst_pt is not None else pos.get(dst, (0, 0))\n"," \n","        arrow = FancyArrowPatch(\n","            posA=p_src, posB=p_dst,\n","            arrowstyle=\"-|>,head_length=10,head_width=6\",\n","            color=color,\n","            linewidth=1.8,\n","            linestyle=ls_map.get(linestyle, \"-\"),\n","            alpha=0.85,\n","            connectionstyle=\"arc3,rad=0.05\",\n","            zorder=4,\n","            transform=ax.transData,   # データ座標系を明示\n","        )\n","        ax.add_patch(arrow)\n"," \n","    # 接続名ラベル (Output以外のみ表示)\n","    edge_labels = {\n","        (s, d): data[\"connection\"]\n","        for s, d, data in G.edges(data=True)\n","        if data.get(\"connection\") not in (\"\", \"Output\", \"Log\", \"Control\", \"Action\", \"Question\", None)\n","    }\n","    nx.draw_networkx_edge_labels(\n","        G, pos, edge_labels=edge_labels, ax=ax,\n","        font_color=\"#CFD8DC\", font_size=7,\n","        bbox=dict(boxstyle=\"round,pad=0.2\", fc=\"#263238\", ec=\"none\", alpha=0.7),\n","    )\n"," \n","    # ── ノード描画 ──\n","    for node_id, (nx_x, nx_y) in pos.items():\n","        # コンテナツール自身はアイコン非表示（囲み矩形で表現済み）\n","        if str(node_id) in container_groups:\n","            continue\n","        data          = G.nodes[node_id]\n","        tool_name     = data.get(\"tool_name\", \"\")\n","        tool_category = data.get(\"tool_category\", \"\")\n","        label         = data.get(\"label\", str(node_id))\n","        color         = _category_color(tool_category)   # ★カテゴリで色を決定\n"," \n","        # アイコン画像 (ToolNameで検索)\n","        icon_img = icon_loader.get(tool_name)\n","        if icon_img is not None:\n","            # 半透明カラーboxでアイコン形状を保ちつつカテゴリ色を表現\n","            im = OffsetImage(icon_img, zoom=1.0, zorder=5)\n","            ab = AnnotationBbox(\n","                im, (nx_x, nx_y), frameon=True,\n","                bboxprops=dict(\n","                    boxstyle=\"round,pad=0.3\",\n","                    facecolor=color, edgecolor=color,\n","                    linewidth=2.0, alpha=0.45,\n","                ),\n","                zorder=5,\n","            )\n","            ax.add_artist(ab)\n","        else:\n","            # フォールバック: カラーサークル + ToolName先頭6文字\n","            short = tool_name[:6] if tool_name else \"?\"\n","            ax.plot(nx_x, nx_y, \"o\",\n","                    markersize=icon_loader.icon_size * 0.55,\n","                    color=color,\n","                    markeredgecolor=\"white\", markeredgewidth=1.5, zorder=5)\n","            ax.text(nx_x, nx_y, short,\n","                    ha=\"center\", va=\"center\",\n","                    fontsize=7, color=\"white\", fontweight=\"bold\", zorder=6)\n"," \n","        # ラベル (ツール名 or アノテーション) ── 長い場合は折り返す\n","        # xytext をポイント単位 (offset_points) で指定することで\n","        # データ座標スケールに依存しない一定の視覚的距離を保つ\n","        wrapped_label = _wrap_label(label, LABEL_WRAP_WIDTH)\n","        ax.annotate(\n","            wrapped_label,\n","            xy=(nx_x, nx_y),\n","            xytext=(0, -(icon_loader.icon_size * 0.5 + LABEL_OFFSET_PT)),\n","            textcoords=\"offset points\",\n","            ha=\"center\", va=\"top\",\n","            fontsize=LABEL_FONTSIZE, color=\"#ECEFF1\", fontweight=\"bold\",\n","            path_effects=[pe.withStroke(linewidth=2, foreground=\"#1E1E2E\")],\n","            zorder=7, clip_on=True,\n","            linespacing=1.4,\n","            annotation_clip=False,\n","        )\n"," \n","        # ToolID バッジ (右上に固定オフセット)\n","        ax.annotate(\n","            f\"#{node_id}\",\n","            xy=(nx_x, nx_y),\n","            xytext=(NODE_ID_OFFSET_PT, NODE_ID_OFFSET_PT),\n","            textcoords=\"offset points\",\n","            ha=\"center\", va=\"center\",\n","            fontsize=NODE_ID_FONTSIZE, color=\"#B0BEC5\", zorder=8,\n","            annotation_clip=False,\n","        )\n"," \n","    # ── タイトル ──\n","    ax.set_title(\n","        r\"Alteryx Workflow\",\n","        color=\"#ECEFF1\", fontsize=14, fontweight=\"bold\", pad=16,\n","    )\n"," \n","    # ── 凡例: 登場したカテゴリ色 + エッジ種別 ──\n","    used_categories = sorted(set(\n","        d.get(\"tool_category\", \"\") for _, d in G.nodes(data=True)\n","        if d.get(\"tool_category\", \"\")\n","    ))\n","    legend_handles = [\n","        mpatches.Patch(color=_category_color(cat), label=cat)\n","        for cat in used_categories\n","    ]\n","    from matplotlib.lines import Line2D\n","    edge_legend_items = [\n","        (\"default\",  \"Normal Connection\"),\n","        (\"true\",     \"True / Match\"),\n","        (\"false\",    \"False / Error\"),\n","        (\"question\", \"Question\"),\n","        (\"action\",   \"Action\"),\n","        (\"control\",  \"Control Connection\"),\n","        (\"wireless\", \"Wireless\"),\n","    ]\n","    legend_handles += [\n","        Line2D([0],[0], color=EDGE_STYLE_MAP[key][0], linewidth=2,\n","               linestyle=EDGE_STYLE_MAP[key][1], label=label)\n","        for key, label in edge_legend_items\n","    ]\n"," \n","    ax.legend(\n","        handles=legend_handles,\n","        loc=\"upper left\",\n","        bbox_to_anchor=(1.01, 1.0),   # axesの右外に配置\n","        borderaxespad=0,\n","        facecolor=\"#263238\", edgecolor=\"#546E7A\",\n","        labelcolor=\"#ECEFF1\", fontsize=8,\n","        title=\"Legend\", title_fontsize=9,\n","    )\n"," \n","    fig.text(0.01, 0.01,\n","             f\"Node Count: {len(G.nodes)}  Connection Count: {len(G.edges)}\",\n","             color=\"#78909C\", fontsize=8)\n"," \n","    # ── 保存 ──\n","    safe_id = str(record_id).replace(\"/\", \"_\").replace(\"\\\\\", \"_\").replace(\":\", \"_\")\n","    out_path = output_dir / f\"workflow_{safe_id}.png\"\n","    plt.savefig(str(out_path), dpi=DPI, bbox_inches=\"tight\",\n","                facecolor=fig.get_facecolor())\n","    plt.close()\n","    gc.collect()\n"," \n","    return str(out_path)\n"," \n"," \n","# ══════════════════════════════════════════════\n","# メイン処理 (Alteryx Pythonツールのエントリポイント)\n","# ══════════════════════════════════════════════\n","def main():\n","    # ── パス解決 ──\n","    # OUTPUT_DIR が設定されていればそちらを使用、空の場合は TempFilePath を自動使用\n","    # ICONS_DIR : ワークフローフォルダ直下の ICONS_SUBDIR\n","    workflow_dir = Alteryx.getWorkflowConstant(\"Engine.WorkflowDirectory\")\n","    if OUTPUT_DIR.strip():\n","        out_dir = Path(OUTPUT_DIR.strip())\n","        print(f\"[Visualizer] OUTPUT_DIR : {out_dir} (User setting)\")\n","    else:\n","        temp_path = Alteryx.getWorkflowConstant(\"Engine.TempFilePath\")\n","        out_dir = Path(temp_path)\n","        print(f\"[Visualizer] OUTPUT_DIR : {out_dir} (TempFilePath Auto Select)\")\n","    icons_dir = Path(workflow_dir) / ICONS_SUBDIR\n","    out_dir.mkdir(parents=True, exist_ok=True)\n","    print(f\"[Visualizer] ICONS_DIR  : {icons_dir}\")\n"," \n","    # ── 入力データ読み込み ──\n","    nodes_all: pd.DataFrame = Alteryx.read(\"#2\")   # ノードテーブル\n","    edges_all: pd.DataFrame = Alteryx.read(\"#1\")   # 接続テーブル\n"," \n","    # ── アイコンローダー (全ワークフロー共通) ──\n","    icon_loader = IconLoader(str(icons_dir), ICON_SIZE)\n"," \n","    # ── Record_ID ごとに処理 ──\n","    results = []\n","    record_ids = nodes_all[\"___Record_ID___\"].unique()\n"," \n","    total = len(record_ids)\n","    print(f\"[Visualizer] start: {total} workflows\")\n"," \n","    for i, record_id in enumerate(record_ids, 1):\n","        nodes_df = nodes_all[nodes_all[\"___Record_ID___\"] == record_id].copy()\n","        edges_df = edges_all[edges_all[\"___Record_ID___\"] == record_id].copy()\n","        print(f\"[Visualizer] ({i}/{total}) ID={record_id} processing \"\n","              f\"(Node Count:{len(nodes_df)} Connection Count:{len(edges_df)})\")\n"," \n","        try:\n","            img_path = visualize_single(\n","                record_id=record_id,\n","                nodes_df=nodes_df,\n","                edges_df=edges_df,\n","                icon_loader=icon_loader,\n","                output_dir=out_dir,\n","            )\n","            print(f\"[Visualizer] ({i}/{total}) ID={record_id} Complete → {img_path}\")\n","            results.append({\n","                \"___Record_ID___\": record_id,\n","                \"ImagePath\":       img_path,\n","                \"NodeCount\":       len(nodes_df),\n","                \"EdgeCount\":       len(edges_df),\n","                \"Status\":          \"Success\",\n","                \"ErrorMessage\":    \"\",\n","            })\n","        except Exception as e:\n","            print(f\"[Visualizer] ({i}/{total}) ID={record_id} Error: {e}\")\n","            results.append({\n","                \"___Record_ID___\": record_id,\n","                \"ImagePath\":       \"\",\n","                \"NodeCount\":       len(nodes_df),\n","                \"EdgeCount\":       len(edges_df),\n","                \"Status\":          \"Error\",\n","                \"ErrorMessage\":    str(e),\n","            })\n"," \n","    print(f\"[Visualizer] Complete: {total} workflows\")\n"," \n","    # ── 結果を下流に出力 ──\n","    result_df = pd.DataFrame(results)\n","    Alteryx.write(result_df, 1)\n"," \n"," \n","main()"],"execution_count":2,"outputs":[]},{"metadata":{},"cell_type":"code","source":[],"execution_count":null,"outputs":[]},{"metadata":{},"cell_type":"code","source":[],"execution_count":null,"outputs":[]}],"metadata":{"kernelspec":{"name":"designerbasetools_venv","display_name":"designerbasetools_venv","language":"python"},"language_info":{"name":"python","version":"3.10.18","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"}},"nbformat":4,"nbformat_minor":2}]]></Notebook>
